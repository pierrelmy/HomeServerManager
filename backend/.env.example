HOST=0.0.0.0
PORT=3000
NODE_ENV=development
SESSION_SECRET=replace-with-at-least-32-random-characters
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=info
READ_AUTH_REQUIRED=false
METRICS_INTERVAL_MS=5000
DATABASE_PATH=./data/homelab.db
ADMIN_EMAIL=admin@localhost.test
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_DISPLAY_NAME=Homelab Admin
SYSTEM_ADAPTER=simulation
SYSTEM_SERVICE_MAP={"ollama":"ollama.service","jenkins":"jenkins.service","docker-engine":"docker.service"}
NAS_SCRUB_COMMAND=["zpool","scrub","pool-data"]
NAS_STATUS_COMMAND=[]
TOOL_COMMANDS={}
METRICS_TOKEN=replace-with-a-random-monitoring-token
