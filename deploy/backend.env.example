HOST=0.0.0.0
PORT=3000
NODE_ENV=production
SESSION_SECRET=replace-with-at-least-32-random-characters
CORS_ORIGINS=https://homelab.example.com
LOG_LEVEL=info
READ_AUTH_REQUIRED=true
METRICS_INTERVAL_MS=5000
METRICS_TOKEN=replace-with-a-random-monitoring-token
DATABASE_PATH=/var/lib/homeservermanager/homelab.db
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-long-random-password
ADMIN_DISPLAY_NAME=Homelab Admin
SYSTEM_ADAPTER=local
SYSTEM_SERVICE_MAP={"ollama":"ollama.service","jenkins":"jenkins.service","docker-engine":"docker.service"}
NAS_SCRUB_COMMAND=["sudo","-n","zpool","scrub","pool-data"]
NAS_STATUS_COMMAND=["/usr/local/libexec/homeservermanager/nas-status"]
TOOL_COMMANDS={"scan-reseau":["/usr/local/libexec/homeservermanager/scan-network"],"update-hsm":["sudo","-n","/bin/bash","/srv/homeservermanager-dev/deploy/update-hsm-dev.sh"]}
