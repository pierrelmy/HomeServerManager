# Install as /etc/sudoers.d/homeservermanager with mode 0440 and validate with visudo -cf.
# Keep this list aligned with SYSTEM_SERVICE_MAP and NAS_SCRUB_COMMAND.
# This allows the backend to execute any root-owned installation script path via /bin/bash.
homelab ALL=(root) NOPASSWD: /bin/bash *
homelab ALL=(root) NOPASSWD: /usr/bin/systemctl start ollama.service
homelab ALL=(root) NOPASSWD: /usr/bin/systemctl stop ollama.service
homelab ALL=(root) NOPASSWD: /usr/bin/systemctl restart ollama.service
homelab ALL=(root) NOPASSWD: /usr/bin/systemctl start jenkins.service
homelab ALL=(root) NOPASSWD: /usr/bin/systemctl stop jenkins.service
homelab ALL=(root) NOPASSWD: /usr/bin/systemctl restart jenkins.service
homelab ALL=(root) NOPASSWD: /usr/bin/systemctl start docker.service
homelab ALL=(root) NOPASSWD: /usr/bin/systemctl stop docker.service
homelab ALL=(root) NOPASSWD: /usr/bin/systemctl restart docker.service
homelab ALL=(root) NOPASSWD: /usr/bin/systemctl start homelab-demo.service
homelab ALL=(root) NOPASSWD: /usr/bin/systemctl stop homelab-demo.service
homelab ALL=(root) NOPASSWD: /usr/bin/systemctl restart homelab-demo.service
homelab ALL=(root) NOPASSWD: /usr/sbin/zpool scrub pool-data
